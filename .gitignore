# Large recording media — keep configs/calibration/scripts, not the data
*.mp4
*.mkv
*.bag
*.ffmpeg.log

# Generated overlay frames / per-folder rviz configs
recordings/**/overlay_poc/
recordings/**/overlay_full_poc/
recordings/**/overlay_rviz_raw.mkv
recordings/**/.rviz_overlay.rviz
recordings/**/.rviz_capture.rviz

# Python
__pycache__/
*.pyc

# Keep these small, useful artifacts (negated so they ARE tracked):
!recordings/**/rviz.rviz
!webcam_extrinsics.json
!webcam_extrinsics_clicked.json
!recordings/**/clicks_*.json
!recordings/recordings.csv
