# cam2 = ABKO APC930 hardware rev 1008 (autofocus + manual focus).
# Both units report no USB serial, so identity is by bcdDevice via the udev rule
# 99-webcam-recorder.rules, which creates this stable symlink (port-independent).
# If cam2 needs a different locked focus than cam1 (different distance to scene),
# add e.g. CAM_FOCUS=30 here (find the value with: CAM_DEVICE=/dev/webcam_cam2 ./camctl.sh sweep).
CAM_DEVICE=/dev/webcam_cam2
CAM_NODE_NAME=recorder_cam2
CAM_TAG=cam2
CAM_IMG_TOPIC=/recorder_cam2/image_raw
CAM_FRAME_ID=camera_cam2
# WB fixed (not auto) to match cam1 — the two sensor revs need different temps for the
# same color. cam2=5000 (cam1=4300 in cam1.env). Overrides the template's CAM_AUTO_WB.
CAM_WB_TEMP=5000
