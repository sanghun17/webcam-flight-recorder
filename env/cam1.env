# cam1 = ABKO APC930 hardware rev 400d (autofocus + manual focus).
# Both units report no USB serial, so identity is by bcdDevice via the udev rule
# 99-webcam-recorder.rules, which creates this stable symlink (port-independent).
CAM_DEVICE=/dev/webcam_cam1
CAM_NODE_NAME=recorder_cam1
CAM_TAG=cam1
CAM_IMG_TOPIC=/recorder_cam1/image_raw
CAM_FRAME_ID=camera_cam1
# WB fixed to match cam2 (different sensor rev needs a different temp for the same color).
CAM_WB_TEMP=4300
